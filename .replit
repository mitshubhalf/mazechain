modules = ["web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash run.sh"
waitForPort = 10000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 8080

[[ports]]
localPort = 10000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "mkdir -p data && PORT=10000 ./mazechain_api"]
build = ["bash", "build.sh"]
